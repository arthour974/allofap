# Cible du proxy Vite pour les requêtes /api/* en développement local.
# En production (S3 + CloudFront), ce fichier n'est pas utilisé :
# CloudFront route /api/* directement vers l'ALB.
#
# Pour le backend local :
API_PROXY_TARGET=http://127.0.0.1:8080
#
# Pour pointer vers l'API AWS DEV :
# API_PROXY_TARGET=https://<cloudfront-dev-domain>
