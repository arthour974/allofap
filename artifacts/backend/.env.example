# Variables d'environnement — copier en .env pour le dev local
# En production, ces valeurs sont injectées par ECS (task definition / Secrets Manager)

DATABASE_URL=postgresql://user:password@localhost:5432/allofap

SESSION_SECRET=change-me-in-production

# Origines autorisées par le CORS (séparées par virgule)
# Laisser vide en dev local (toutes les origines sont acceptées hors production)
ALLOWED_ORIGINS=

PORT=8080
NODE_ENV=development
