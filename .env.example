# Branche Neon dev — copier vers .env (ne pas committer .env)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Webhook Shopify (HMAC)
SHOPIFY_WEBHOOK_SECRET=

# Photos / médias — local : laisser vide (fichiers dans ./uploads)
# Production : bucket Terraform allofap-{env}-medias
MEDIA_S3_BUCKET=
AWS_REGION=us-west-2
